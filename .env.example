# Copy this file to .env and fill in real values.
# .env is gitignored - never commit real API keys.

# Your OpenAI API key (required for real_runtime).
OPENAI_API_KEY=sk-REPLACE_ME

# Model used by Actor / Evaluator / Reflector.
# Use a DELIBERATELY WEAK model so the lesson (Reflexion improving over ReAct) is visible.
# Good picks: gpt-3.5-turbo, gpt-4o-mini.
LAB_LLM_MODEL=gpt-3.5-turbo

# Sampling temperature. Keep at 0 for reproducibility + cache stability.
LAB_LLM_TEMPERATURE=0

# Where cached LLM responses are stored (JSON file).
# Delete this file to force fresh API calls.
LAB_LLM_CACHE=.llm_cache.json
